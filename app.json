{
  "expo": {
    "name": "CamTip",
    "slug": "camtip",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/images/icon.png",
    "scheme": "camtip",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.camtip.app",
      "deploymentTarget": "16.0",
      "buildNumber": "2"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      },
      "package": "com.camtip.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      [
        "expo-camera",
        {
          "cameraPermission": "CamTip needs camera access to scan your bill."
        }
      ],
      [
        "./plugins/withMinimumDeploymentTarget",
        "16.0"
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "23775844-fc6a-46bf-aa2e-1cc465859975"
      }
    }
  }
}
