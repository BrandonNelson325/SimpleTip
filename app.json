{
  "expo": {
    "name": "CamTip",
    "slug": "camtip",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/images/icon.png",
    "scheme": "camtip",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.camtip.app",
      "deploymentTarget": "16.0",
      "buildNumber": "11",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "googleMobileAdsAppId": "ca-app-pub-4471669474742212~7511704873"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      },
      "package": "com.camtip.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      [
        "expo-camera",
        {
          "cameraPermission": "CamTip needs camera access to scan your bill."
        }
      ],
      [
        "./plugins/withMinimumDeploymentTarget",
        "16.0"
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-4471669474742212~7511704873"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5ef78ca3-9ae0-41f3-b3e3-d3e5bc2083d5"
      }
    },
    "owner": "brandonnelson325"
  }
}
