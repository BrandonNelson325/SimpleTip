{
  "expo": {
    "name": "SimpleTip",
    "slug": "simple-tip",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "simpletip",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.simpletip.app",
      "deploymentTarget": "16.0"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      },
      "package": "com.simpletip.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      [
        "expo-camera",
        {
          "cameraPermission": "SimpleTip needs camera access to scan your bill."
        }
      ],
      ["./plugins/withMinimumDeploymentTarget", "16.0"]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "23775844-fc6a-46bf-aa2e-1cc465859975"
      }
    }
  }
}
